# Cloudflare Pages redirect rules.
#
# Format: <from> <to> <status>
# See https://developers.cloudflare.com/pages/configuration/redirects/
#
# ─── 2026-05-18: glossary → termbase URL migration ────────────────
# The Workbench help pages moved from /workbench/glossaries/* and
# /workbench/superlookup/glossary-search/ to /workbench/termbases/*
# and /workbench/superlookup/termbase-search/ for terminology
# consistency (the Workbench UI calls them termbases throughout,
# and v1.10.62+ uses that term in every dialog and tooltip).
#
# 301 redirects so:
#   - External backlinks to the old URLs (anywhere on the web)
#     don't 404
#   - In-app help links from older installed Workbench versions
#     (modules/help_system.py's HelpTopics enum had the old paths
#     baked in; updated in v1.10.76 but already-installed copies
#     still ship the old strings) still land on the right page
#   - Trados plugin v4.19.114 and earlier had no cross-product
#     links to these specific Workbench help pages, but defensive
#     here anyway
#
# Splat redirect covers all six files in the renamed folder in one
# rule; explicit rule for the renamed file in superlookup/.

/workbench/glossaries/*                  /workbench/termbases/:splat              301
/workbench/superlookup/glossary-search/  /workbench/superlookup/termbase-search/  301

# ─── 2026-05-20: page moves ───────────────────────────────────────
# "File Format Reference" was merged into Import & Export and became the
# Supervertaler Bilingual Table page.
/workbench/reference/file-formats/       /workbench/import-export/bilingual-tables/  301
# AutoFingers was renamed to Voice (this redirect previously lived only in the
# now-unused .gitbook.yaml, so it never actually fired on Cloudflare Pages).
/workbench/sidekick/autofingers/         /workbench/voice/overview/                  301

# ─── 2026-05-21: QuickTrans/MT pages moved out of SuperLookup & Companion Tabs ───
# Machine Translation, Custom MT endpoint and the QuickTrans popup now live in a
# dedicated /workbench/quicktrans/ section (they are not part of SuperLookup or
# the companion tabs structurally or in the app).
/workbench/superlookup/mt/ /workbench/quicktrans/machine-translation/ 301
/workbench/superlookup/custom-mt-endpoint/ /workbench/quicktrans/custom-mt-endpoint/ 301
/workbench/sidekick/quicktrans-popup/ /workbench/quicktrans/overview/ 301

# ─── 2026-05-21: "Companion Tabs" section dissolved ───────────────
# The artificial "Companion Tabs" grouping was removed. Voice and the
# Clipboard Manager are now their own top-level sections; Chat moved
# under AI Translation; the Companion Tabs Overview page was deleted.
/workbench/sidekick/overview/            /workbench/voice/overview/                  301
/workbench/sidekick/voice/               /workbench/voice/overview/                  301
/workbench/sidekick/clipboard/           /workbench/clipboard/overview/              301
/workbench/sidekick/trados-aware-chat/   /workbench/ai-translation/chat/             301
