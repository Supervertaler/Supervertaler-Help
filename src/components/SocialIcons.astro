---
/**
 * Custom SocialIcons override for Starlight.
 *
 * Replaces the default icon-row (two GitHub icons + a generic external
 * icon for supervertaler.com) with three text buttons matching the
 * convention from the legacy GitBook header:
 *
 *   - Supervertaler.com  (primary / filled)
 *   - GitHub             (outline) — links to the org page (which
 *                        has both repos one click away)
 *   - Beijer.uk          (outline)
 *
 * The `social` array in astro.config.mjs is intentionally ignored here
 * because the default Starlight icon-row doesn't allow per-link styling
 * and we want one of them to be visually primary.  Edit the URLs in
 * this file directly to change them.
 *
 * Hidden on narrow viewports (Starlight already hides the right-group
 * on mobile by default to make room for the menu toggle).
 */
---

<div class="sv-header-buttons">
  <a
    class="sv-btn sv-btn-primary"
    href="https://supervertaler.com"
    target="_blank"
    rel="noopener"
    title="Supervertaler product website — features, pricing and downloads"
  >
    Supervertaler.com
  </a>
  <a
    class="sv-btn sv-btn-outline"
    href="https://github.com/Supervertaler"
    target="_blank"
    rel="noopener"
    title="Browse the source code, report bugs and request features on GitHub"
  >
    GitHub
  </a>
  <a
    class="sv-btn sv-btn-outline"
    href="https://beijer.uk"
    target="_blank"
    rel="noopener"
    title="Author's website — Michael Beijer"
  >
    Beijer.uk
  </a>
</div>

<style>
  .sv-header-buttons {
    align-items: center;
    display: flex;
    gap: 0.375rem;
  }

  .sv-btn {
    align-items: center;
    border-radius: 0.5rem;
    display: inline-flex;
    font-family: var(--sl-font);
    font-size: var(--sl-text-sm);
    font-weight: 500;
    line-height: 1;
    padding: 0.5rem 0.875rem;
    text-decoration: none;
    transition: background-color 0.15s ease, border-color 0.15s ease,
      color 0.15s ease;
    white-space: nowrap;
  }

  /* ── Primary (Supervertaler.com) ──────────────────────────────── */
  .sv-btn-primary {
    /* Brand blue — sits well on both light and dark.  Hard-coded
       rather than using --sl-color-accent so it doesn't track the
       default Starlight purple. */
    background-color: #2563eb;
    border: 1px solid #2563eb;
    color: #ffffff;
  }
  .sv-btn-primary:hover {
    background-color: #1d4ed8;
    border-color: #1d4ed8;
    color: #ffffff;
  }

  /* ── Outline (GitHub, Beijer.uk) ──────────────────────────────── */
  .sv-btn-outline {
    background-color: transparent;
    border: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-white);
  }
  .sv-btn-outline:hover {
    background-color: var(--sl-color-gray-6);
    border-color: var(--sl-color-gray-4);
    color: var(--sl-color-white);
  }
</style>
